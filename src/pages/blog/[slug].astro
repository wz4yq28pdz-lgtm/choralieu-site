---
import Base from '../../layouts/Base.astro';
import { getPosts, notionConfigured } from '../../lib/notion';
import { renderMarkdown } from '../../lib/markdown';

export async function getStaticPaths() {
  if (!notionConfigured()) return [];
  const posts = await getPosts();
  return posts.map((p) => ({
    params: { slug: p.slug },
    props: { post: p },
  }));
}

const { post } = Astro.props as {
  post: Awaited<ReturnType<typeof getPosts>>[number];
};
const html = renderMarkdown(post.markdown);
---
<Base title={`${post.title} — Choralieu`} description={post.excerpt}>
  <article>
    <h1>{post.title}</h1>
    <div class="meta">
      {post.lastEdited && new Date(post.lastEdited).toLocaleDateString()}
      {post.tags?.length ? ` · ${post.tags.join(', ')}` : ''}
    </div>
    {post.coverImageUrl && (
      <img src={post.coverImageUrl} alt="" style="max-width:100%;border-radius:8px;margin-bottom:1.5rem;" />
    )}
    <div set:html={html} />
  </article>
</Base>
