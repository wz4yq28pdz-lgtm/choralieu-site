---
import Base from '../layouts/Base.astro';
import { getPosts, notionConfigured } from '../lib/notion';

let posts: Awaited<ReturnType<typeof getPosts>> = [];
if (notionConfigured()) {
  try {
    posts = await getPosts();
  } catch (err) {
    console.warn('[notion] getPosts failed:', (err as Error).message);
  }
}
const recent = posts.slice(0, 5);
---
<Base title="Choralieu" description="Choralieu is a public field notebook for creative work, systems thinking, and long-form reflection.">
  <h1>Choralieu</h1>

  <p>
    Choralieu is a public field notebook for creative work, systems thinking,
    and long-form reflection.
  </p>

  <p>
    Essays, project notes, and updates are published here from the Choralieu
    Notion workspace.
  </p>

  {recent.length > 0 ? (
    <>
      <h2>Recent posts</h2>
      <ul class="post-list">
        {recent.map((p) => (
          <li>
            <a href={`/blog/${p.slug}/`}>{p.title}</a>
            {p.excerpt && <p class="summary">{p.excerpt}</p>}
          </li>
        ))}
      </ul>
    </>
  ) : (
    <p class="meta">
      No Notion content yet. Set <code>NOTION_API_KEY</code> and{' '}
      <code>NOTION_PUBLIC_DB_ID</code> in <code>.env</code>, then re-run the build.
    </p>
  )}
</Base>
