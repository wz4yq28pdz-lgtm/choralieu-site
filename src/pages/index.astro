---
import Base from '../layouts/Base.astro';
import { getPosts, notionConfigured } from '../lib/notion';

let posts: Awaited<ReturnType<typeof getPosts>> = [];
if (notionConfigured()) {
  try {
    posts = await getPosts();
  } catch (err) {
    console.warn('[notion] getPosts failed:', (err as Error).message);
  }
}
const recent = posts.slice(0, 5);
---
<Base title="Argota" description="Welcome to Argota.">
  <h1>Argota</h1>
  <p>
    A small site, scaffolded and ready to grow. Edit <code>src/pages/index.astro</code>
    to make this your own. Content below is pulled from Notion when
    <code>NOTION_TOKEN</code> and <code>NOTION_DATABASE_ID</code> are set.
  </p>

  {recent.length > 0 ? (
    <>
      <h2>Recent posts</h2>
      <ul class="post-list">
        {recent.map((p) => (
          <li>
            <a href={`/blog/${p.slug}/`}>{p.title}</a>
            {p.summary && <p class="summary">{p.summary}</p>}
          </li>
        ))}
      </ul>
    </>
  ) : (
    <p class="meta">
      No Notion content yet. Set <code>NOTION_TOKEN</code> and{' '}
      <code>NOTION_DATABASE_ID</code> in <code>.env</code>, then re-run the build.
    </p>
  )}
</Base>
