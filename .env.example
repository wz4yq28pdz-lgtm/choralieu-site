# Notion API credentials
# Create an integration at https://www.notion.so/my-integrations
NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# The Notion database ID that backs the site content (Pages / Posts).
# Share the database with your integration before using.
NOTION_DATABASE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional: separate database for blog posts. Falls back to NOTION_DATABASE_ID.
NOTION_POSTS_DATABASE_ID=

# Public site URL (used for sitemap, RSS, canonical links)
SITE_URL=https://argota.example.com

# Optional: filter Notion items by a "Status" select property
# e.g. only render items where Status = "Published"
NOTION_STATUS_FILTER=Published

# Anthropic API key (reserved — not yet used by the build).
# Will power future build-time content steps.
ANTHROPIC_API_KEY=
