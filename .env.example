# Notion API credentials.
# Create an integration at https://www.notion.so/profile/integrations
# (capabilities: Read + Update + Insert content) and connect it to the
# parent page that contains the databases below.
NOTION_API_KEY=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PUBLIC database — static pages (About, etc.). Required.
NOTION_PUBLIC_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# PRIVATE database — posts. Required.
NOTION_PRIVATE_DB_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Public site URL (used for sitemap, RSS, canonical links)
SITE_URL=https://choralieu.pages.dev

# Optional: filter Notion items by a "Status" select property
# e.g. only render items where Status = "Published".
# Set to empty string to disable filtering.
NOTION_STATUS_FILTER=Published

# Anthropic API key (reserved — not yet used by the build).
# Will power future build-time content steps.
ANTHROPIC_API_KEY=
